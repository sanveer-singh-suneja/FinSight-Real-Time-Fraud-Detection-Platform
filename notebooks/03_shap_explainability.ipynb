{
 "cells": [
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "# FinSight – SHAP Explainability\n",
    "\n",
    "Interactive exploration of SHAP values for the trained fraud model."
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "import sys\n",
    "sys.path.insert(0, '..')\n",
    "\n",
    "import warnings\n",
    "warnings.filterwarnings('ignore')\n",
    "\n",
    "from pathlib import Path\n",
    "import numpy as np\n",
    "import pandas as pd\n",
    "import shap\n",
    "import matplotlib.pyplot as plt\n",
    "\n",
    "from ml.model_loader import load_model_bundle\n",
    "from ml.explainability import (\n",
    "    compute_shap_values,\n",
    "    plot_summary,\n",
    "    plot_bar_importance,\n",
    "    compute_local_explanation,\n",
    ")\n",
    "\n",
    "shap.initjs()\n",
    "print('Ready')"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# Load model\n",
    "bundle = load_model_bundle(Path('../models'))\n",
    "print(f'Model: {bundle.model_name} | Threshold: {bundle.threshold}')\n",
    "print(f'Features: {len(bundle.feature_cols)}')"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# Load validation data\n",
    "val_path = Path('../data/validation/X_val.parquet')\n",
    "if val_path.exists():\n",
    "    X_val = pd.read_parquet(val_path)\n",
    "    X_val = X_val[bundle.feature_cols].fillna(0)\n",
    "    print(f'Validation set: {len(X_val):,} rows')\n",
    "else:\n",
    "    print('No validation data found. Using synthetic data.')\n",
    "    from producer.synthetic_generator import generate_synthetic_transactions\n",
    "    txns = generate_synthetic_transactions(200)\n",
    "    X_val = pd.DataFrame(txns)[bundle.feature_cols].fillna(0)"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# Compute SHAP values on a sample\n",
    "sample = X_val.sample(min(300, len(X_val)), random_state=42).reset_index(drop=True)\n",
    "\n",
    "print(f'Computing SHAP values on {len(sample)} samples...')\n",
    "shap_values, explainer = compute_shap_values(bundle.model, sample)\n",
    "print(f'SHAP values shape: {shap_values.shape}')"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# Summary plot (beeswarm)\n",
    "plt.figure(figsize=(12, 8))\n",
    "shap.summary_plot(shap_values, sample, max_display=20, show=True)"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# Bar importance plot\n",
    "mean_abs = np.abs(shap_values).mean(axis=0)\n",
    "importance = pd.Series(mean_abs, index=sample.columns).sort_values(ascending=False)\n",
    "\n",
    "fig, ax = plt.subplots(figsize=(10, 8))\n",
    "importance.head(20).sort_values().plot.barh(ax=ax, color='steelblue')\n",
    "ax.set_title('Top 20 Features – Mean |SHAP Value|')\n",
    "ax.set_xlabel('Mean |SHAP Value|')\n",
    "plt.tight_layout()\n",
    "plt.show()\n",
    "\n",
    "print('Top 10 features:')\n",
    "for feat, val in importance.head(10).items():\n",
    "    print(f'  {feat}: {val:.6f}')"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# Waterfall plot for a single prediction\n",
    "idx = 0\n",
    "row = sample.iloc[[idx]]\n",
    "score = bundle.predict_proba(row)[0]\n",
    "print(f'Transaction #{idx}: fraud score = {score:.4f}')\n",
    "\n",
    "explanation = compute_local_explanation(bundle.model, row, explainer, top_n=10)\n",
    "print('\\nTop contributing features:')\n",
    "for feat_info in explanation['top_features']:\n",
    "    direction = '▲' if feat_info['shap_value'] > 0 else '▼'\n",
    "    print(f\"  {direction} {feat_info['feature']}: value={feat_info['value']:.3g}, SHAP={feat_info['shap_value']:+.4f}\")"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# Dependence plot for top feature\n",
    "top_feature = importance.index[0]\n",
    "print(f'Dependence plot for: {top_feature}')\n",
    "\n",
    "feat_idx = list(sample.columns).index(top_feature)\n",
    "fig, ax = plt.subplots(figsize=(10, 6))\n",
    "shap.dependence_plot(\n",
    "    feat_idx,\n",
    "    shap_values,\n",
    "    sample,\n",
    "    show=False,\n",
    "    ax=ax,\n",
    ")\n",
    "ax.set_title(f'SHAP Dependence – {top_feature}')\n",
    "plt.tight_layout()\n",
    "plt.show()"
   ]
  }
 ],
