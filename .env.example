# ─────────────────── Application ───────────────────
APP_ENV=production
LOG_LEVEL=INFO
SECRET_KEY=your-super-secret-key-at-least-32-characters-long

# ─────────────────── PostgreSQL ───────────────────
POSTGRES_USER=finsight
POSTGRES_PASSWORD=finsight_secret
POSTGRES_DB=finsight
POSTGRES_HOST=postgres
POSTGRES_PORT=5432

# ─────────────────── Redis ───────────────────
REDIS_PASSWORD=redis_secret
REDIS_HOST=redis
REDIS_PORT=6379

# ─────────────────── Kafka ───────────────────
KAFKA_BOOTSTRAP_SERVERS=kafka:29092
KAFKA_TOPIC_TRANSACTIONS=txn-events
KAFKA_TOPIC_DECISIONS=fraud-decisions
KAFKA_TOPIC_ALERTS=alerts
KAFKA_TOPIC_DLQ=dead-letter
KAFKA_CONSUMER_GROUP=finsight-consumer-group

# ─────────────────── MLflow ───────────────────
MLFLOW_TRACKING_URI=http://mlflow:5000
MLFLOW_EXPERIMENT_NAME=fraud-detection

# ─────────────────── Model ───────────────────
MODEL_PATH=/app/models
MODEL_VERSION=latest

# ─────────────────── Webhooks ───────────────────
WEBHOOK_URL=https://hooks.example.com/fraud-alerts
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/YOUR/SLACK/WEBHOOK
DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/YOUR/DISCORD/WEBHOOK
TEAMS_WEBHOOK_URL=https://outlook.office.com/webhook/YOUR/TEAMS/WEBHOOK

# ─────────────────── Grafana ───────────────────
GRAFANA_USER=admin
GRAFANA_PASSWORD=admin_secure_password

# ─────────────────── Transaction Simulator ───────────────────
TRANSACTION_RATE=10

# ─────────────────── AWS (for deployment) ───────────────────
AWS_REGION=us-east-1
AWS_ACCOUNT_ID=123456789012
AWS_ECR_REPOSITORY=finsight
AWS_EC2_HOST=your-ec2-host.compute.amazonaws.com
AWS_EC2_KEY_PATH=~/.ssh/finsight-key.pem

# ─────────────────── Rate Limiting ───────────────────
RATE_LIMIT_PER_MINUTE=100
RATE_LIMIT_PER_HOUR=5000

# ─────────────────── Feature Flags ───────────────────
ENABLE_SHAP_EXPLANATION=true
ENABLE_RULE_ENGINE=true
ENABLE_KAFKA_PRODUCER=true
FRAUD_ALERT_THRESHOLD=0.8
REVIEW_THRESHOLD=0.5
